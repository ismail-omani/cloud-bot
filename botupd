#!/bin/bash
#for linux only
kill $(cat bot.pid)
cd ~/cloud-bot
git update-index --skip-worktree users.txt
git update-index --skip-worktree output.log
git update-index --skip-worktree bot.pid
git update-index --skip-worktree cloudtoken
git update-index --skip-worktree config.py
git ls-files files/ | xargs git update-index --skip-worktree
git ls-files -v | grep ^S
git pull origin main
echo Bot is updated. Follow the instructions:
echo
echo "cd cloud-bot"
echo "source venv/bin/activate"
echo 'tmux new -s bot'
exho
echo 'Then you will appear in tmux session. Run "python3 bot.py" to run bot'
echo 'To disattach press Ctrl+B, then D'
echo 'To return back to session: tmux attach -t bot'
